<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--     Wizard: National ID OCR — kser.national.id.wizard        -->
        <!-- ============================================================ -->
        <record id="view_kser_national_id_wizard_form" model="ir.ui.view">
            <field name="name">kser.national.id.wizard.form</field>
            <field name="model">kser.national.id.wizard</field>
            <field name="arch" type="xml">
                <form string="معالج استخراج بيانات الهوية">
                    <sheet>
                        <group string="نوع التسجيل" invisible="target_type != 'beneficiary'">
                            <group>
                                <field name="is_child" string="تسجيل كطفل (بدون هوية)"/>
                            </group>
                            <group invisible="not is_child">
                                <field name="head_of_family_id" string="رب الأسرة" required="is_child"/>
                            </group>
                        </group>

                        <!-- Stage 1: Upload -->
                        <group invisible="state != 'upload' or is_child" string="رفع صورة الهوية">
                            <group>
                                <field name="id_image" string="صورة الهوية الوطنية"
                                       filename="id_image_filename" widget="binary" required="state == 'upload' and not is_child"/>
                                <field name="id_image_filename" invisible="1"/>
                            </group>
                        </group>

                        <!-- Stage 2: Review / Manual entry -->
                        <group>
                            <group string="البيانات الشخصية">
                                <field name="extracted_name" string="الاسم الكامل"/>
                                <field name="extracted_mother_name" string="اسم الوالدة" invisible="is_child"/>
                                <field name="extracted_national_id" string="رقم الهوية" required="state == 'review' and not is_child" invisible="is_child" readonly="not is_manual_entry"/>
                                <field name="extracted_profession" string="المهنة" invisible="is_child"/>
                                <field name="extracted_marital_status" string="الحالة الاجتماعية" invisible="is_child"/>
                            </group>
                            <group string="بيانات إضافية">
                                <field name="extracted_dob" string="تاريخ الميلاد"/>
                                <field name="extracted_gender" string="الجنس"/>
                                <field name="is_disabled" string="ذوو احتياجات خاصة"/>
                            </group>
                        </group>

                        <!-- Attach image in review state (for manual entry) -->
                        <group invisible="state != 'review' or not is_manual_entry or is_child">
                            <field name="id_image" string="إرفاق صورة الهوية "
                                   filename="id_image_filename" widget="binary" required="state == 'review' and is_manual_entry and not is_child"/>
                        </group>

                        <field name="target_type" invisible="1"/>
                        <field name="state" invisible="1"/>
                        <field name="is_manual_entry" invisible="1"/>
                    </sheet>
                    <footer class="oe_edit_only">
                        <button name="action_extract_data" type="object"
                                string="استخراج البيانات" class="btn-primary"
                                invisible="state != 'upload' or is_child"/>
                        <button name="action_manual_entry" type="object"
                                string="إدخال يدوي" class="btn-secondary"
                                invisible="state != 'upload' or is_child"/>
                        <button name="action_manual_entry" type="object"
                                string="متابعة التسجيل" class="btn-primary"
                                invisible="state != 'upload' or not is_child"/>
                        <button name="action_confirm_and_save" type="object"
                                string="تأكيد وحفظ" class="btn-primary"
                                invisible="state != 'review'"/>
                        <button string="إلغاء" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_kser_national_id_wizard" model="ir.actions.act_window">
            <field name="name">معالج استخراج الهوية (AI)</field>
            <field name="res_model">kser.national.id.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_target_type': 'beneficiary'}</field>
        </record>

        <record id="action_kser_national_id_wizard_volunteer" model="ir.actions.act_window">
            <field name="name">معالج استخراج الهوية للمتطوع (AI)</field>
            <field name="res_model">kser.national.id.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_target_type': 'volunteer'}</field>
        </record>

        <!-- ============================================================ -->
        <!--   Wizard: Bank Receipt OCR — kser.bank.receipt.wizard        -->
        <!-- ============================================================ -->
        <record id="view_kser_bank_receipt_wizard_form" model="ir.ui.view">
            <field name="name">kser.bank.receipt.wizard.form</field>
            <field name="model">kser.bank.receipt.wizard</field>
            <field name="arch" type="xml">
                <form string="معالج استخراج بيانات الإيصال البنكي">
                    <sheet>
                        <!-- Stage 1: Upload -->
                        <group invisible="state != 'upload'" string="رفع صورة الإيصال">
                            <group>
                                <field name="receipt_image" string="صورة الإيصال البنكي"
                                       filename="receipt_image_filename" widget="binary" required="1"/>
                                <field name="receipt_image_filename" invisible="1"/>
                                <field name="campaign_id" string="الحملة المرتبطة"/>
                            </group>
                        </group>

                        <!-- Stage 2: Review / Manual entry -->
                        <group invisible="state != 'review'" string="بيانات الإيصال">
                            <group string="بيانات العملية">
                                <field name="extracted_transaction_id" string="رقم العملية" required="state == 'review'"/>
                                <field name="extracted_amount" string="المبلغ"/>
                                <field name="extracted_bank_name" string="اسم البنك"/>
                                <field name="extracted_date" string="التاريخ"/>
                            </group>
                            <group string="بيانات الحسابات">
                                <field name="extracted_sender_account" string="حساب المرسل"/>
                                <field name="extracted_receiver_account" string="حساب المستلم"/>

                                <field name="campaign_id" string="الحملة المرتبطة"
                                       invisible="not is_manual_entry"/>
                            </group>
                        </group>

                        <!-- Attach image in review state (for manual entry) -->
                        <group invisible="state != 'review' or not is_manual_entry">
                            <field name="receipt_image" string="إرفاق صورة الإيصال"
                                   filename="receipt_image_filename" widget="binary" required="1"/>
                        </group>

                        <field name="state" invisible="1"/>
                        <field name="is_manual_entry" invisible="1"/>
                    </sheet>
                    <footer class="oe_edit_only">
                        <button name="action_extract_data" type="object"
                                string="استخراج البيانات" class="btn-primary"
                                invisible="state != 'upload'"/>
                        <button name="action_manual_entry" type="object"
                                string="إدخال يدوي" class="btn-secondary"
                                invisible="state != 'upload'"/>
                        <button name="action_confirm_and_save" type="object"
                                string="تأكيد وحفظ" class="btn-primary"
                                invisible="state != 'review'"/>
                        <button string="إلغاء" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action to open Bank Receipt Wizard -->
        <record id="action_kser_bank_receipt_wizard" model="ir.actions.act_window">
            <field name="name">معالج استخراج الإيصال البنكي (AI)</field>
            <field name="res_model">kser.bank.receipt.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================================ -->
        <!--    Wizard: Import Donors — kser.donor.import.wizard           -->
        <!-- ============================================================ -->
        <record id="view_kser_donor_import_wizard_form" model="ir.ui.view">
            <field name="name">kser.donor.import.wizard.form</field>
            <field name="model">kser.donor.import.wizard</field>
            <field name="arch" type="xml">
                <form string="معالج استيراد كشوفات المتبرعين">
                    <sheet>
                        <group string="بيانات الاستيراد">
                            <group>
                                <field name="file" string="ملف Excel"
                                       filename="file_name"/>
                                <field name="file_name" invisible="1"/>
                            </group>
                            <group>
                                <field name="project_id" string="الحملة"/>
                            </group>
                        </group>
                    </sheet>
                    <footer class="oe_edit_only">
                        <button name="process_import_data" type="object"
                                string="استيراد البيانات" class="btn-primary"/>
                        <button string="إلغاء" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action to open Donor Import Wizard -->
        <record id="action_kser_donor_import_wizard" model="ir.actions.act_window">
            <field name="name">استيراد كشوفات المتبرعين</field>
            <field name="res_model">kser.donor.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- ============================================================ -->
        <!--  Wizard: Smart Distribution — kser.inventory.wizard                 -->
        <!-- ============================================================ -->

        <record id="view_kser_inventory_wizard_form" model="ir.ui.view">
            <field name="name">kser.inventory.wizard.form</field>
            <field name="model">kser.inventory.wizard</field>
            <field name="arch" type="xml">
                <form string="فحص فجوات تغطية الأدوية" create="0" delete="0">
                    <field name="state" invisible="1"/>
                    <sheet>
                        <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                            <strong>ملاحظة:</strong>
                            سيقوم النظام بتحليل المخزون الدوائي الحالي ومطابقته مع المستفيدين المسجلين كأصحاب أمراض مزمنة لتحديد الفجوات والثغرات في التغطية الطبية.
                        </div>

                        <!-- Results Section -->
                        <div invisible="state != 'result'">
                            <h2 class="mb16">تقرير فحص حالة المخزون والثغرات</h2>
                            <group>
                                <field name="summary" string="ملخص التغطية" readonly="1"/>
                                <field name="urgency_report" string="الحالات الحرجة والعاجلة" readonly="1"/>
                            </group>
                            <h3 class="mt16 mb8">الحالات غير المغطاة بالدواء (Uncovered Cases)</h3>
                            <field name="uncovered_case_ids" readonly="1">
                                <list>
                                    <field name="national_id_number" string="الرقم الوطني"/>
                                    <field name="beneficiary_id" string="الاسم"/>
                                    <field name="health_conditions" string="المرض"/>
                                    <field name="needed_medicine" string="العلاج المقترح"/>
                                    <field name="justification" string="التبرير الطبي وسبب الاختيار"/>
                                </list>
                            </field>
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_analyze_inventory_gap" type="object"
                                string="بدء الفحص" class="oe_highlight btn-primary"
                                invisible="state != 'draft'"/>
                        <button string="إغلاق" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_kser_inventory_wizard" model="ir.actions.act_window">
            <field name="name">فحص حالة المخزون</field>
            <field name="res_model">kser.inventory.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>


        <!-- ============================================================ -->
        <!--     Wizard: Report Generator — kser.report.wizard           -->
        <!-- ============================================================ -->
        <record id="view_kser_report_wizard_form" model="ir.ui.view">
            <field name="name">kser.report.wizard.form</field>
            <field name="model">kser.report.wizard</field>
            <field name="arch" type="xml">
                <form string="طباعة التقارير">
                    <group>
                        <field name="report_type"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="opening_balance" invisible="report_type != 'budget'"/>
                    </group>
                    <footer>
                        <button name="action_print_report" string="تحميل التقرير (PDF)" type="object" class="btn-primary"/>
                        <button string="إلغاء" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_kser_report_volunteers" model="ir.actions.act_window">
            <field name="name">تقرير إنجاز المتطوعين الميدانيين</field>
            <field name="res_model">kser.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_report_type': 'volunteers'}</field>
        </record>

        <record id="action_kser_report_performance" model="ir.actions.act_window">
            <field name="name">تقرير أداء الغرفة وحجم المساعدات</field>
            <field name="res_model">kser.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_report_type': 'performance'}</field>
        </record>

        <record id="action_kser_report_budget" model="ir.actions.act_window">
            <field name="name">تقرير الميزانية التشغيلية</field>
            <field name="res_model">kser.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_report_type': 'budget'}</field>
        </record>

        <record id="action_kser_report_clinic" model="ir.actions.act_window">
            <field name="name">تقرير أداء العيادة</field>
            <field name="res_model">kser.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_report_type': 'clinic'}</field>
        </record>

    </data>
</odoo>
