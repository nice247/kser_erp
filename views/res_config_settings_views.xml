<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--          KSER Settings: res.config.settings form             -->
        <!-- ============================================================ -->
        <record id="view_res_config_settings_form_kser" model="ir.ui.view">
            <field name="name">res.config.settings.form.kser</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="غرفة الطوارئ" string="غرفة الطوارئ"
                         name="kser_erp">
                        <block title="إعدادات قراءة الهوية والإيصالات (Gemini API)"
                               name="kser_api_settings">
                            <setting string="مزود الذكاء الاصطناعي"
                                     help="اختيار مزود الذكاء الاصطناعي وإعداداته">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="kser_ai_provider" class="col-lg-3"/>
                                        <field name="kser_ai_provider" required="1"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="kser_ai_model" class="col-lg-3"/>
                                        <field name="kser_ai_model" placeholder="مثال: gemini-2.5-flash أو llava"/>
                                    </div>
                                    <div class="row mt16" invisible="kser_ai_provider != 'gemini'">
                                        <label for="kser_ai_api_key" class="col-lg-3"/>
                                        <field name="kser_ai_api_key"
                                               password="True"
                                               placeholder="أدخل مفتاح الـ API..."/>
                                    </div>
                                    <div class="row mt16" invisible="kser_ai_provider != 'ollama'">
                                        <label for="kser_local_llm_url" class="col-lg-3"/>
                                        <field name="kser_local_llm_url"
                                               placeholder="مثال: http://localhost:11434/api/generate"/>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
