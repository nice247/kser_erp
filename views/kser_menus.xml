<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--              Window Actions for all models                   -->
        <!-- ============================================================ -->

        <!-- Beneficiaries Action -->
        <record id="action_kser_beneficiary" model="ir.actions.act_window">
            <field name="name">المستفيدين</field>
            <field name="res_model">kser.beneficiary</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_kser_beneficiary_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا يوجد مستفيدين حالياً
                </p>
                <p>اضغط لإضافة مستفيد جديد.</p>
            </field>
        </record>

        <!-- Cash Donations Action -->
        <record id="action_kser_cash_donation" model="ir.actions.act_window">
            <field name="name">التبرعات النقدية</field>
            <field name="res_model">kser.cash.donation</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_kser_cash_donation_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد تبرعات مسجلة
                </p>
                <p>اضغط لتسجيل تبرع نقدي جديد.</p>
            </field>
        </record>

        <!-- Field Tasks Action (project.task) -->
        <record id="action_kser_field_tasks" model="ir.actions.act_window">
            <field name="name">المهام الميدانية</field>
            <field name="res_model">project.task</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد مهام ميدانية حالياً
                </p>
                <p>اضغط لإنشاء مهمة ميدانية جديدة.</p>
            </field>
        </record>

        <!-- Volunteers Action (res.partner filtered by category) -->
        <record id="action_kser_volunteers" model="ir.actions.act_window">
            <field name="name">المتطوعين</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_res_partner_tree_kser"/>
            <field name="domain" eval="[('category_tag', '=', ref('partner_category_volunteer')), ('user_ids', '=', False), ('is_company', '=', False)]"/>
            <field name="context" eval="{'default_category_tag': ref('partner_category_volunteer')}"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا يوجد متطوعين مسجلين حالياً
                </p>
                <p>اضغط لإضافة متطوع جديد.</p>
            </field>
        </record>

        <!-- Inventory / Stock Picking Action -->
        <record id="action_kser_stock_picking" model="ir.actions.act_window">
            <field name="name">عمليات التوزيع</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد عمليات توزيع حالياً
                </p>
                <p>اضغط لإنشاء عملية توزيع جديدة.</p>
            </field>
        </record>

        <!-- Audit Log Action -->
        <record id="action_kser_audit_log" model="ir.actions.act_window">
            <field name="name">سجل التدقيق</field>
            <field name="res_model">kser.audit.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_kser_audit_log_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد سجلات تدقيق
                </p>
            </field>
        </record>

        <!-- All Contacts Action -->
        <record id="action_kser_contacts" model="ir.actions.act_window">
            <field name="name">جهات الاتصال</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="view_id" ref="view_res_partner_tree_kser"/>
            <field name="context">{'create': False}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد جهات اتصال
                </p>
            </field>
        </record>

        <!-- Donors Action -->
        <record id="action_kser_donors" model="ir.actions.act_window">
            <field name="name">المتبرعين</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_res_partner_tree_donors"/>
            <field name="domain" eval="[('category_tag', '=', ref('partner_category_donor'))]"/>
            <field name="context" eval="{'default_category_tag': ref('partner_category_donor')}"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا يوجد متبرعين مسجلين حالياً
                </p>
                <p>اضغط لإضافة متبرع جديد.</p>
            </field>
        </record>

        <!-- Partners Action (res.partner filtered by is_company = True) -->
        <record id="action_kser_partners" model="ir.actions.act_window">
            <field name="name">الشركاء</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_res_partner_tree_partners"/>
            <field name="domain" eval="[('is_company', '=', True)]"/>
            <field name="context" eval="{'default_is_company': True}"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا يوجد شركاء مسجلين حالياً
                </p>
                <p>اضغط لإضافة شريك جديد.</p>
            </field>
        </record>

        <!-- Projects / Campaigns Action -->
        <record id="action_kser_campaigns" model="ir.actions.act_window">
            <field name="name">الحملات</field>
            <field name="res_model">project.project</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    لا توجد حملات حالياً
                </p>
                <p>اضغط لإنشاء حملة جديدة.</p>
            </field>
        </record>

        <!-- Settings Action (KSER Settings Page) -->
        <record id="action_kser_settings" model="ir.actions.act_window">
            <field name="name">إعدادات غرفة الطوارئ</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module': 'kser_erp'}</field>
        </record>

        <!-- ============================================================ -->
        <!--                  Main Menu: غرفة الطوارئ                     -->
        <!-- ============================================================ -->
        <menuitem id="menu_kser_root"
                  name="غرفة الطوارئ"
                  action="action_kser_emergency_dashboard"
                  web_icon="kser_erp,static/description/icon.png"
                  groups="base.group_user"
                  sequence="1"/>

        <!-- ============================================================ -->
        <!--               Level 1: Sub-Menu Categories                   -->
        <!-- ============================================================ -->

        <menuitem id="menu_kser_dashboard"
                  name="لوحة القيادة"
                  parent="menu_kser_root"
                  action="action_kser_emergency_dashboard"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin,kser_erp.group_data_manager,kser_erp.group_stock_manager,kser_erp.group_field_supervisor,kser_erp.group_doctor,kser_erp.group_pharmacist,kser_erp.group_clinic_manager,kser_erp.group_receptionist"
                  sequence="1"
                  active="True"/>

        <!-- 1. التوزيع والمستفيدين -->
        <menuitem id="menu_kser_contacts"
                  name="التوزيع والمستفيدين"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_stock_manager,kser_erp.group_field_supervisor,kser_erp.group_system_admin"
                  sequence="5"/>

        <!-- 2. الشركاء والمتطوعين -->
        <menuitem id="menu_kser_partners_volunteers"
                  name="الشركاء والمتطوعين"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_field_supervisor,kser_erp.group_system_admin"
                  sequence="10"/>


        <!-- العيادة الطبية -->
        <menuitem id="menu_kser_clinic"
                  name="العيادة الطبية"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_pharmacist,kser_erp.group_receptionist,kser_erp.group_system_admin"
                  sequence="15"/>

        <menuitem id="menu_kser_clinic_visit_today"
                  name="طابور العيادة اليومي"
                  parent="menu_kser_clinic"
                  action="action_kser_clinic_visit_today"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_receptionist,kser_erp.group_system_admin"
                  sequence="1"/>

        <menuitem id="menu_kser_prescription"
                  name="الروشتات الطبية"
                  parent="menu_kser_clinic"
                  action="action_kser_prescription"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_pharmacist,kser_erp.group_system_admin"
                  sequence="2"/>

        <menuitem id="menu_kser_prescription_pending"
                  name="الروشتات قيد انتظار الصرف"
                  parent="menu_kser_clinic"
                  action="action_kser_prescription_pending_dispense"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_pharmacist,kser_erp.group_system_admin"
                  sequence="3"/>

        <menuitem id="menu_kser_child_followup"
                  name="متابعة سوء التغذية للأطفال"
                  parent="menu_kser_clinic"
                  action="action_kser_child_followup"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_system_admin"
                  sequence="3"/>

        <menuitem id="menu_kser_child_followup_schedule"
                  name="جدول زيارات المتابعة"
                  parent="menu_kser_clinic"
                  action="action_kser_child_followup_schedule"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_receptionist,kser_erp.group_doctor,kser_erp.group_system_admin"
                  sequence="4"/>

        <menuitem id="menu_kser_clinic_visit_all"
                  name="سجل الزيارات التاريخي"
                  parent="menu_kser_clinic"
                  action="action_kser_clinic_visit_history"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_receptionist,kser_erp.group_system_admin"
                  sequence="5"/>

        <menuitem id="menu_kser_inventory_wizard"
                  name="فحص حالة المخزون"
                  parent="menu_kser_clinic"
                  action="action_kser_inventory_wizard"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_system_admin"
                  sequence="6"/>

        <!-- 3. التبرعات -->
        <menuitem id="menu_kser_donations"
                  name="التبرعات"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_system_admin"
                  sequence="20"/>

        <!-- 4. المهام والحملات -->
        <menuitem id="menu_kser_field_tasks"
                  name="المهام والحملات"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"
                  sequence="30"/>

        <!-- 7. الضبط -->
        <menuitem id="menu_kser_settings"
                  name="الضبط"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="99"/>

        <!-- ============================================================ -->
        <!--             Level 2: Action Menu Items                       -->
        <!-- ============================================================ -->

        <record id="menu_kser_partners" model="ir.ui.menu">
            <field name="name">الشركاء</field>
            <field name="parent_id" ref="menu_kser_partners_volunteers"/>
            <field name="action" ref="action_kser_partners"/>
            <field name="sequence" eval="1"/>
            <field name="groups_id" eval="[(6, 0, [ref('group_admin_supervisor'), ref('group_system_admin')])]"/>
        </record>

        <record id="menu_kser_volunteers" model="ir.ui.menu">
            <field name="name">المتطوعين</field>
            <field name="parent_id" ref="menu_kser_partners_volunteers"/>
            <field name="action" ref="action_kser_volunteers"/>
            <field name="sequence" eval="2"/>
            <field name="groups_id" eval="[(6, 0, [ref('group_admin_supervisor'), ref('group_data_manager'), ref('group_field_supervisor'), ref('group_system_admin')])]"/>
        </record>

        <record id="menu_kser_volunteer_ocr_wizard" model="ir.ui.menu">
            <field name="name">إضافة متطوع</field>
            <field name="parent_id" ref="menu_kser_partners_volunteers"/>
            <field name="action" ref="action_kser_national_id_wizard_volunteer"/>
            <field name="sequence" eval="3"/>
            <field name="groups_id" eval="[(6, 0, [ref('group_admin_supervisor'), ref('group_data_manager'), ref('group_field_supervisor'), ref('group_system_admin')])]"/>
            <field name="active" eval="True"/>
        </record>

        <record id="menu_kser_donors" model="ir.ui.menu">
            <field name="name">المتبرعين</field>
            <field name="parent_id" ref="menu_kser_donations"/>
            <field name="action" ref="action_kser_donors"/>
            <field name="sequence" eval="2"/>
            <field name="groups_id" eval="[(6, 0, [ref('group_admin_supervisor'), ref('group_data_manager'), ref('group_system_admin')])]"/>
        </record>

        <!-- المستفيدين Sub-Items -->
        <menuitem id="menu_kser_beneficiary_list"
                  name="المستفيدين"
                  parent="menu_kser_contacts"
                  action="action_kser_beneficiary"
                  sequence="1"/>

        <menuitem id="menu_kser_beneficiary_ocr_wizard"
                  name="إضافة مستفيد"
                  parent="menu_kser_contacts"
                  action="action_kser_national_id_wizard"
                  sequence="4"
                  active="True"/>

        <!-- التبرعات Sub-Items -->
        <menuitem id="menu_kser_donation_list"
                  name="التبرعات النقدية"
                  parent="menu_kser_donations"
                  action="action_kser_cash_donation"
                  sequence="1"/>

        <menuitem id="menu_kser_receipt_ocr_wizard"
                  name="إضافة تبرع"
                  parent="menu_kser_donations"
                  action="action_kser_bank_receipt_wizard"
                  sequence="3"
                  active="True"/>

        <menuitem id="menu_kser_donor_import_wizard"
                  name="استيراد كشوفات المتبرعين"
                  parent="menu_kser_donations"
                  action="action_kser_donor_import_wizard"
                  sequence="4"/>

        <!-- المصروفات Sub-Items -->
        <menuitem id="menu_kser_cash_expense_list"
                  name="المصروفات والحوافز"
                  parent="menu_kser_field_tasks"
                  action="action_kser_cash_expense"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="3"/>

        <!-- المهام والحملات Sub-Items -->
        <menuitem id="menu_kser_campaigns"
                  name="الحملات"
                  parent="menu_kser_field_tasks"
                  action="action_kser_campaigns"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"
                  sequence="1"/>

        <menuitem id="menu_kser_field_tasks_list"
                  name="قائمة المهام"
                  parent="menu_kser_field_tasks"
                  action="action_kser_field_tasks"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"
                  sequence="2"/>


        <!-- المخزون والتوزيع Sub-Items -->
        <menuitem id="menu_kser_stock_picking_list"
                  name="عمليات التوزيع"
                  parent="menu_kser_contacts"
                  action="action_kser_stock_picking"
                  groups="kser_erp.group_stock_manager,kser_erp.group_system_admin"
                  sequence="2"/>


        <!-- الضبط Sub-Items -->
        <menuitem id="menu_kser_settings_params"
                  name="إعدادات النظام"
                  parent="menu_kser_settings"
                  action="action_kser_settings"
                  groups="kser_erp.group_system_admin"
                  sequence="1"/>

        <menuitem id="menu_kser_audit_log_list"
                  name="سجل التدقيق"
                  parent="menu_kser_settings"
                  action="action_kser_audit_log"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="2"/>

        <!-- التقارير Parent Menu -->
        <menuitem id="menu_kser_reports"
                  name="التقارير"
                  parent="menu_kser_root"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin,kser_erp.group_clinic_manager"
                  sequence="55"/>

        <!-- التقارير Sub-Items -->
        <menuitem id="menu_kser_report_volunteers"
                  name="تقرير إنجاز المتطوعين الميدانيين"
                  parent="menu_kser_reports"
                  action="action_kser_report_volunteers"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="1"/>

        <menuitem id="menu_kser_report_performance"
                  name="تقرير أداء الغرفة وحجم المساعدات"
                  parent="menu_kser_reports"
                  action="action_kser_report_performance"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="2"/>

        <menuitem id="menu_kser_report_budget"
                  name="تقرير الميزانية التشغيلية"
                  parent="menu_kser_reports"
                  action="action_kser_report_budget"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                  sequence="3"/>

        <menuitem id="menu_kser_report_clinic"
                  name="تقرير أداء العيادة"
                  parent="menu_kser_reports"
                  action="action_kser_report_clinic"
                  groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin,kser_erp.group_clinic_manager"
                  sequence="4"/>

        <!-- ============================================================ -->
        <!--             تقييد قوائم النظام الأساسية                       -->
        <!-- ============================================================ -->

        <!-- منيو التطبيقات يظهر لمدير النظام فقط -->
        <menuitem id="base.menu_management" groups="kser_erp.group_system_admin"/>

        <!-- جهات الاتصال القياسي -->
        <record id="contacts.menu_contacts" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <record id="contacts.action_contacts" model="ir.actions.act_window">
            <field name="context">{'create': False}</field>
        </record>

        <!-- المشاريع القياسي -->
        <menuitem id="project.menu_main_pm" groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>

        <!-- المخزن القياسي -->
        <menuitem id="stock.menu_stock_root" groups="kser_erp.group_stock_manager,kser_erp.group_system_admin"/>

        <!-- إخفاء الفوترة من الروت الرئيسي تماماً بكافة الصلاحيات -->
        <record id="account.menu_finance" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <!-- المناقشة والمراسلات القياسي -->
        <record id="mail.menu_root_discuss" model="ir.ui.menu">
            <field name="sequence" eval="100"/>
        </record>

        <!-- لوحة عمل جداول البيانات القياسي -->
        <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <!-- المهام الشخصية القياسية -->
        <record id="project_todo.menu_todo_todos" model="ir.ui.menu">
            <field name="sequence" eval="110"/>
        </record>
    </data>
</odoo>
