<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--       KSER Custom Tree View: res.partner (volunteers/donors) -->
        <!-- ============================================================ -->
        <record id="view_res_partner_tree_kser" model="ir.ui.view">
            <field name="name">res.partner.list.kser</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="جهات الاتصال" default_order="create_date desc" js_class="kser_ocr_list">
                    <field name="name" string="الاسم"/>
                    <field name="category_tag" string="التصنيف"/>
                    <field name="national_id_number" string="الرقم الوطني"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="email" string="البريد الإلكتروني"/>
                    <field name="supervisor_id" string="المشرف الميداني" optional="hide"/>
                    <field name="city" string="المدينة" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_res_partner_tree_donors" model="ir.ui.view">
            <field name="name">res.partner.list.donors</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="المتبرعين" default_order="create_date desc">
                    <field name="name" string="الاسم"/>
                    <field name="category_tag" string="التصنيف"/>
                    <field name="city" string="المدينة"/>
                    <field name="phone" string="الهاتف"/>
                </list>
            </field>
        </record>
        <record id="view_res_partner_tree_partners" model="ir.ui.view">
            <field name="name">res.partner.list.partners</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="الشركاء" default_order="create_date desc">
                    <field name="name" string="الاسم"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="email" string="البريد الإلكتروني"/>
                    <field name="city" string="المدينة" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--       Inherited View: res.partner form — KSER fields         -->
        <!-- ============================================================ -->
        <record id="view_res_partner_form_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="before">
                    <header>
                        <button name="%(kser_erp.action_kser_national_id_wizard_volunteer)d" type="action" 
                                string="قراءة الهوية (AI)" class="oe_highlight" 
                                invisible="not id or not is_volunteer"/>
                    </header>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="id" invisible="1"/>
                    <field name="is_volunteer" invisible="1"/>
                    <field name="is_donor" invisible="1"/>
                    <field name="is_beneficiary" invisible="1"/>
                    <button name="action_view_volunteer_tasks" type="object"
                            class="oe_stat_button" icon="fa-tasks"
                            invisible="not is_volunteer"
                            groups="kser_erp.group_field_supervisor,kser_erp.group_admin_supervisor,kser_erp.group_system_admin">
                        <div class="o_stat_info">
                            <field name="task_count" class="o_stat_value"/>
                            <span class="o_stat_text">المهام الميدانية</span>
                        </div>
                    </button>
                    <button name="action_view_incentives" type="object"
                            class="oe_stat_button" icon="fa-money"
                            invisible="not is_volunteer"
                            groups="kser_erp.group_field_supervisor,kser_erp.group_admin_supervisor,kser_erp.group_system_admin">
                        <div class="o_stat_info">
                            <field name="incentive_total" class="o_stat_value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <span class="o_stat_text">الحوافز (<field name="incentive_count"/>)</span>
                        </div>
                    </button>
                    <button name="action_view_donations" type="object"
                            class="oe_stat_button" icon="fa-money"
                            invisible="not is_donor">
                        <div class="o_stat_info">
                            <field name="donation_count" class="o_stat_value"/>
                            <span class="o_stat_text">التبرعات النقدية</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//field[@name='company_type']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='parent_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='company_name']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='create_company']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='function']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='website']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='title']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='lang']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='email']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='mobile']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='street']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='street2']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='zip']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='state_id']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='country_id']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//div[hasclass('o_address_format')]" position="before">
                    <field name="category_tag" string="التصنيف" invisible="not is_donor"/>
                </xpath>
                <xpath expr="//page[@name='internal_notes']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="سجل التبرعات" invisible="not is_donor">
                        <field name="donation_ids" readonly="1"/>
                    </page>
                </xpath>
                <xpath expr="//span[@name='address_name']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='contact_addresses']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='sales_purchases']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//sheet//group" position="after">
                    <group string="بيانات KSER" name="kser_identity_group" invisible="is_company or is_donor">
                        <group string="التصنيف">
                            <field name="category_tag" string="تصنيف جهة الاتصال"/>
                            <field name="supervisor_id" string="المشرف الميداني" invisible="is_donor"/>
                            <label for="whatsapp_number" string="رقم الواتساب" invisible="not is_volunteer"/>
                            <div class="o_row" invisible="not is_volunteer">
                                <field name="whatsapp_number" placeholder="مثال: 0912345678"/>
                                <button name="action_open_whatsapp" type="object" class="btn-success" icon="fa-whatsapp" title="مراسلة عبر واتساب" invisible="not whatsapp_number"/>
                            </div>
                            <field name="volunteer_completion_rate" invisible="not is_volunteer" widget="progressbar"/>
                        </group>
                        <group string="بيانات الهوية" invisible="is_donor">
                            <field name="national_id_number" string="رقم الهوية الوطنية" required="is_volunteer"/>
                            <field name="national_id_image" string="صورة الهوية" widget="image"
                                   class="oe_avatar" options="{'size': [2048, 2048]}" required="is_volunteer" readonly="1"/>

                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: project.task form — KSER fields          -->
        <!-- ============================================================ -->
        <record id="view_project_task_form_inherit_kser" model="ir.ui.view">
            <field name="name">project.task.form.inherit.kser</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <!-- إخفاء الحقول غير المطلوبة لمسؤولي الطوارئ -->
                <xpath expr="//field[@name='user_ids']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='date_deadline']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='tag_ids']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//notebook" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                
                <!-- إضافة بيانات التقييم بعد بيانات الحملة -->
                <xpath expr="//group" position="after">
                    <group string="بيانات التقييم والتكليف (KSER)" name="kser_evaluation_group">
                        <field name="available_volunteer_ids" invisible="1"/>
                        <group colspan="2">
                            <field name="task_volunteer_ids" string="ساعات وتفاصيل المتطوعين المكلفين">
                                <list editable="bottom">
                                    <field name="available_volunteer_ids" invisible="1"/>
                                    <field name="volunteer_id" string="المتطوع" domain="[('id', 'in', available_volunteer_ids)]" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="hours_worked" string="ساعات العمل"/>
                                    <field name="completion_rate" string="نسبة الإنجاز %"/>
                                    <field name="incentive_amount" string="الحافز المالي" sum="إجمالي الحوافز"/>
                                </list>
                            </field>
                        </group>
                        <group>
                            <field name="picking_id" string="إذن التوزيع المرتبط"/>
                        </group>
                        <group>
                            <field name="completion_rate" string="نسبة الإنجاز العامة %"/>
                            <field name="evaluation_notes" string="ملاحظات التقييم"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: stock.picking form — KSER fields         -->
        <!-- ============================================================ -->
        <record id="view_stock_picking_form_inherit_kser" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.kser</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[('is_clinic_only', '=', False)]</attribute>
                </xpath>
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="project_id" string="الحملة المرتبطة"/>
                    <field name="prescriber_id" string="الطبيب المعالج/الكاتب"/>
                </xpath>
                <xpath expr="//sheet" position="inside">
                    <group string="التوزيع والذكاء الاصطناعي (KSER)" name="kser_distribution_group">
                        <group>
                            <field name="distribution_type" string="نوع التوزيع"/>
                        </group>
                        <group>
                            <field name="ai_suggestion" string="اقتراح الذكاء الاصطناعي"
                                    widget="boolean_toggle"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_stock_picking_tree_inherit_kser" model="ir.ui.view">
            <field name="name">stock.picking.tree.inherit.kser</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="replace"/>
                <xpath expr="//field[@name='priority']" position="before">
                    <field name="partner_id" string="جهة الاتصال" optional="show" readonly="state in ['cancel', 'done']"/>
                    <field name="national_id_number" string="الرقم الوطني" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='name']" position="replace"/>
                <xpath expr="//field[@name='state']" position="before">
                    <field name="name" decoration-bf="1" string="الرقم المرجعي"/>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: project.project form — KSER budget        -->
        <!-- ============================================================ -->
        <record id="view_project_project_form_inherit_kser" model="ir.ui.view">
            <field name="name">project.project.form.inherit.kser</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="attributes">
                    <attribute name="edit">state != 'done'</attribute>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="before">
                    <widget name="web_ribbon" title="مكتملة" bg_color="text-bg-success" invisible="state != 'done'"/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <!-- Add state buttons to header -->
                <xpath expr="//header" position="inside">
                    <button name="action_approve_budget" type="object" string="اعتماد الميزانية"
                            class="oe_highlight" invisible="state != 'draft'"
                            groups="kser_erp.group_admin_supervisor"/>
                    <button name="action_close_campaign" type="object" string="إغلاق الحملة"
                            class="oe_highlight" invisible="state != 'approved'"
                            groups="kser_erp.group_admin_supervisor"/>
                    <button name="action_draft_budget" type="object" string="إرجاع لمسودة"
                            invisible="state not in ('approved', 'done')"
                            groups="kser_erp.group_admin_supervisor"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,done"/>
                </xpath>
                <!-- Add budget fields -->
                <xpath expr="//group" position="inside">
                    <group string="ميزانية KSER" name="kser_budget_group">
                        <field name="budget_amount" string="قيمة الميزانية" readonly="state == 'approved'"/>
                        <field name="currency_id" string="العملة" readonly="state == 'approved'"/>
                    </group>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_pickings" type="object"
                            class="oe_stat_button" icon="fa-truck">
                        <div class="o_stat_info">
                            <field name="picking_count" class="o_stat_value"/>
                            <span class="o_stat_text">عمليات التوزيع</span>
                        </div>
                    </button>
                    <button name="action_view_donations" type="object"
                            class="oe_stat_button" icon="fa-money">
                        <div class="o_stat_info">
                            <field name="donation_count" class="o_stat_value"/>
                            <span class="o_stat_text">التبرعات النقدية</span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>

        <record id="view_project_kanban_inherit_kser" model="ir.ui.view">
            <field name="name">project.project.kanban.inherit.kser</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban" position="attributes">
                    <attribute name="default_group_by">state</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_project_project_tree_inherit_kser" model="ir.ui.view">
            <field name="name">project.project.tree.inherit.kser</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_buttons_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.buttons.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.partner_view_buttons"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_partner_invoices']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or is_company or is_donor</attribute>
                </xpath>
                <xpath expr="//field[@name='supplier_invoice_count']/.." position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or is_company or supplier_invoice_count == 0 or is_donor</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_task_partner_info_form_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.task.buttons.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="project.view_task_partner_info_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_tasks']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_property_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.property.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.view_partner_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='accounting']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or (not is_company and parent_id) or is_donor</attribute>
                </xpath>
                <xpath expr="//page[@name='accounting_disabled']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or (is_company or not parent_id) or is_donor</attribute>
                </xpath>
            </field>
        </record>

        <record id="product_template_form_view_inherit_kser" model="ir.ui.view">
            <field name="name">product.template.form.inherit.kser</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="البيانات الطبية" name="medical_info" invisible="not is_therapeutic">
                        <group>
                            <group>
                                <field name="is_therapeutic" invisible="1"/>
                                <field name="category_path_names" invisible="1"/>
                                <field name="active_ingredient" string="المادة الفعالة"/>
                            </group>
                            <group>
                                <field name="medical_indications" string="دواعي الاستعمال"/>
                                <field name="contraindications" string="موانع الاستعمال"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <template id="webclient_bootstrap_inherit" inherit_id="web.webclient_bootstrap">
            <xpath expr="//meta[@name='theme-color']" position="attributes">
                <attribute name="content">#0c3246</attribute>
            </xpath>
        </template>

        <!-- إخفاء تبويب متابعة المدفوعات (Payment Follow-up) -->
        <record id="view_partner_inherit_followup_form_hide" model="ir.ui.view">
            <field name="name">res.partner.followup.form.hide</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="om_account_followup.view_partner_inherit_followup_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='followup_tab']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <!-- إخفاء زر أرقام المجموعات / الأرقام التسلسلية (Lot/Serial Numbers) -->
        <record id="view_partner_stock_warnings_form_hide_lots" model="ir.ui.view">
            <field name="name">res.partner.stock.warnings.form.hide.lots</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="stock.view_partner_stock_warnings_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_stock_lots']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
