<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--       KSER Custom Tree View: res.partner (volunteers/donors) -->
        <!-- ============================================================ -->
        <record id="view_res_partner_tree_kser" model="ir.ui.view">
            <field name="name">res.partner.list.kser</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="جهات الاتصال" default_order="create_date desc">
                    <field name="name" string="الاسم"/>
                    <field name="category_tag" string="التصنيف"/>
                    <field name="national_id_number" string="الرقم الوطني"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="email" string="البريد الإلكتروني"/>
                    <field name="supervisor_id" string="المشرف الميداني" optional="hide"/>
                    <field name="city" string="المدينة" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_res_partner_tree_donors" model="ir.ui.view">
            <field name="name">res.partner.list.donors</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="المتبرعين" default_order="create_date desc">
                    <field name="name" string="الاسم"/>
                    <field name="city" string="المدينة"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="category_tag" string="التصنيف"/>
                </list>
            </field>
        </record>
        <record id="view_res_partner_tree_partners" model="ir.ui.view">
            <field name="name">res.partner.list.partners</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="الشركاء" default_order="create_date desc">
                    <field name="name" string="الاسم"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="email" string="البريد الإلكتروني"/>
                    <field name="city" string="المدينة" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--       Inherited View: res.partner form — KSER fields         -->
        <!-- ============================================================ -->
        <record id="view_res_partner_form_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="is_volunteer" invisible="1"/>
                    <field name="is_donor" invisible="1"/>
                    <field name="is_beneficiary" invisible="1"/>
                    <button name="action_view_tasks" type="object"
                            class="oe_stat_button" icon="fa-tasks"
                            invisible="not is_volunteer">
                        <div class="o_stat_info">
                            <field name="task_count" class="o_stat_value"/>
                            <span class="o_stat_text">المهام الميدانية</span>
                        </div>
                    </button>
                    <button name="action_view_donations" type="object"
                            class="oe_stat_button" icon="fa-money"
                            invisible="not is_donor">
                        <div class="o_stat_info">
                            <field name="donation_count" class="o_stat_value"/>
                            <span class="o_stat_text">التبرعات النقدية</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//field[@name='company_type']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='parent_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='company_name']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//button[@name='create_company']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='function']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='website']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='title']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='lang']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='email']" position="attributes">
                    <attribute name="invisible">is_donor</attribute>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page string="سجل التبرعات" invisible="not is_donor">
                        <field name="donation_ids" readonly="1"/>
                    </page>
                </xpath>
                <xpath expr="//span[@name='address_name']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='contact_addresses']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='sales_purchases']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//sheet//group" position="after">
                    <group string="بيانات KSER" name="kser_identity_group" invisible="is_company">
                        <group string="التصنيف والإشراف">
                            <field name="category_tag" string="تصنيف جهة الاتصال"/>
                            <field name="supervisor_id" string="المشرف الميداني" invisible="is_donor"/>
                        </group>
                        <group string="بيانات الهوية" invisible="is_donor">
                            <field name="national_id_number" string="رقم الهوية الوطنية" required="is_volunteer"/>
                            <field name="national_id_image" string="صورة الهوية" widget="image"
                                   class="oe_avatar" required="is_volunteer"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: project.task form — KSER fields          -->
        <!-- ============================================================ -->
        <record id="view_project_task_form_inherit_kser" model="ir.ui.view">
            <field name="name">project.task.form.inherit.kser</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="بيانات التقييم والتكليف (KSER)" name="kser_evaluation_group">
                        <group>
                            <field name="volunteer_id" string="المتطوع المكلف"/>
                            <field name="picking_id" string="إذن التوزيع المرتبط"/>
                        </group>
                        <group>
                            <field name="completion_rate" string="نسبة الإنجاز" widget="progressbar"/>
                            <field name="evaluation_notes" string="ملاحظات التقييم"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: stock.picking form — KSER fields         -->
        <!-- ============================================================ -->
        <record id="view_stock_picking_form_inherit_kser" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.kser</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="project_id" string="الحملة المرتبطة"/>
                </xpath>
                <xpath expr="//sheet" position="inside">
                    <group string="التوزيع والذكاء الاصطناعي (KSER)" name="kser_distribution_group">
                        <group>
                            <field name="distribution_type" string="نوع التوزيع"/>
                        </group>
                        <group>
                            <field name="ai_suggestion" string="اقتراح الذكاء الاصطناعي"
                                    widget="boolean_toggle"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--     Inherited View: project.project form — KSER budget        -->
        <!-- ============================================================ -->
        <record id="view_project_project_form_inherit_kser" model="ir.ui.view">
            <field name="name">project.project.form.inherit.kser</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <!-- Add state buttons to header -->
                <xpath expr="//header" position="inside">
                    <button name="action_approve_budget" type="object" string="اعتماد الميزانية"
                            class="oe_highlight" invisible="state != 'draft'"
                            groups="kser_erp.group_admin_supervisor"/>
                    <button name="action_draft_budget" type="object" string="إرجاع لمسودة"
                            invisible="state != 'approved'"
                            groups="kser_erp.group_admin_supervisor"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved"/>
                </xpath>
                <!-- Add budget fields -->
                <xpath expr="//group" position="inside">
                    <group string="ميزانية KSER" name="kser_budget_group">
                        <field name="budget_amount" string="قيمة الميزانية" readonly="state == 'approved'"/>
                        <field name="currency_id" string="العملة" readonly="state == 'approved'"/>
                    </group>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_pickings" type="object"
                            class="oe_stat_button" icon="fa-truck">
                        <div class="o_stat_info">
                            <field name="picking_count" class="o_stat_value"/>
                            <span class="o_stat_text">عمليات التوزيع</span>
                        </div>
                    </button>
                    <button name="action_view_donations" type="object"
                            class="oe_stat_button" icon="fa-money">
                        <div class="o_stat_info">
                            <field name="donation_count" class="o_stat_value"/>
                            <span class="o_stat_text">التبرعات النقدية</span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>

        <record id="view_project_project_tree_inherit_kser" model="ir.ui.view">
            <field name="name">project.project.tree.inherit.kser</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_buttons_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.buttons.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.partner_view_buttons"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_partner_invoices']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or is_company</attribute>
                </xpath>
                <xpath expr="//field[@name='supplier_invoice_count']/.." position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or is_company or supplier_invoice_count == 0</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_task_partner_info_form_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.task.buttons.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="project.view_task_partner_info_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_tasks']" position="attributes">
                    <attribute name="invisible">not is_volunteer</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_property_inherit_kser" model="ir.ui.view">
            <field name="name">res.partner.form.property.inherit.kser</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.view_partner_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='accounting']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or (not is_company and parent_id)</attribute>
                </xpath>
                <xpath expr="//page[@name='accounting_disabled']" position="attributes">
                    <attribute name="invisible">is_volunteer or is_beneficiary or (is_company or not parent_id)</attribute>
                </xpath>
            </field>
        </record>

        <template id="webclient_bootstrap_inherit" inherit_id="web.webclient_bootstrap">
            <xpath expr="//meta[@name='theme-color']" position="attributes">
                <attribute name="content">#0c3246</attribute>
            </xpath>
        </template>
    </data>
</odoo>
