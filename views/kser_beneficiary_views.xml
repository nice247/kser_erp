<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Search View                    -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_search" model="ir.ui.view">
            <field name="name">kser.beneficiary.search</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <search string="بحث في المستفيدين">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="district" string="المحلية"/>
                    <separator/>
                    <filter name="filter_verified" string="تم التحقق" domain="[('is_verified', '=', True)]"/>
                    <filter name="filter_not_verified" string="لم يتم التحقق" domain="[('is_verified', '=', False)]"/>
                    <separator/>
                    <filter name="filter_urgent" string="أولوية عاجلة" domain="[('priority_level', '=', 'urgent')]"/>
                    <filter name="filter_medium" string="أولوية متوسطة" domain="[('priority_level', '=', 'medium')]"/>
                    <separator/>
                    <group expand="0" string="تجميع حسب">
                        <filter name="group_district" string="المحلية" context="{'group_by': 'district'}"/>
                        <filter name="group_priority" string="مستوى الأولوية" context="{'group_by': 'priority_level'}"/>
                        <filter name="group_marital" string="الحالة الاجتماعية" context="{'group_by': 'marital_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Tree View                      -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_tree" model="ir.ui.view">
            <field name="name">kser.beneficiary.list</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <list string="المستفيدين"
                      decoration-danger="priority_level == 'urgent'"
                      decoration-warning="priority_level == 'medium'">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="district" string="المحلية"/>
                    <field name="family_size" string="عدد أفراد الأسرة"/>
                    <field name="priority_level" string="مستوى الأولوية"/>
                    <field name="priority_score" string="درجة الأولوية" optional="hide"/>
                    <field name="registration_date" string="تاريخ التسجيل" optional="hide"/>
                    <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Form View                      -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_form" model="ir.ui.view">
            <field name="name">kser.beneficiary.form</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <form string="بيانات المستفيد">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_moves" type="object"
                                    class="oe_stat_button" icon="fa-truck">
                                <div class="o_stat_info">
                                    <field name="move_count" class="o_stat_value"/>
                                    <span class="o_stat_text">المساعدات المستلمة</span>
                                </div>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="تم التحقق" bg_color="text-bg-success"
                                invisible="not is_verified"/>
                        <widget name="web_ribbon" title="لم يتم التحقق" bg_color="text-bg-danger"
                                invisible="is_verified"/>
                        <div class="oe_title">
                            <h1>
                                <field name="partner_id" string="اسم المستفيد" placeholder="اختر جهة اتصال..."/>
                            </h1>
                        </div>

                        <group>
                            <group string="البيانات الأساسية">
                                <field name="national_id_number" string="رقم الهوية الوطنية"/>
                                <field name="phone" string="رقم الهاتف"/>
                                <field name="mobile" string="رقم الجوال"/>
                                <field name="relationship" string="العلاقة برب الأسرة"/>
                                <field name="head_of_family_id" string="رب الأسرة المسؤول" invisible="relationship == 'self'"/>
                                <field name="profession" string="المهنة"/>
                                <field name="marital_status" string="الحالة الاجتماعية"/>
                                <field name="birthdate" string="تاريخ الميلاد"/>
                                <field name="family_size" string="عدد أفراد الأسرة"/>
                                <field name="district" string="المحلية"/>
                            </group>
                            <group string="الهوية الوطنية">
                                <field name="national_id_image" string="صورة الهوية الوطنية"
                                       widget="image" class="oe_avatar" options="{'size': [2048, 2048]}"/>
                            </group>
                            <group string="التسجيل والتحقق">
                                <field name="registration_date" string="تاريخ التسجيل"/>
                                <field name="registered_by" string="مسجّل بواسطة"/>
                                <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                                <field name="ocr_confidence" string="دقة التعرف الآلي"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="أفراد الأسرة" name="family_members" invisible="relationship != 'self'">
                                <field name="member_ids">
                                    <list editable="bottom">
                                        <field name="partner_id" string="اسم المستفيد"/>
                                        <field name="national_id_number" string="رقم الهوية الوطنية"/>
                                        <field name="phone" string="رقم الهاتف"/>
                                        <field name="relationship" string="العلاقة برب الأسرة"/>
                                        <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                            <page string="الأولوية والحالة الصحية" name="page_priority">
                                <group>
                                    <group string="الأولوية">
                                        <field name="priority_score" string="درجة الأولوية"/>
                                        <field name="priority_level" string="مستوى الأولوية"/>
                                    </group>
                                    <group string="الحالة الصحية">
                                        <field name="health_conditions" string="الأمراض المزمنة"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Graph View                     -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_graph" model="ir.ui.view">
            <field name="name">kser.beneficiary.graph</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <graph string="المستفيدين" type="pie" sample="1">
                    <field name="priority_level"/>
                </graph>
            </field>
        </record>

    </data>
</odoo>
