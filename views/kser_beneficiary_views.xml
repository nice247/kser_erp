<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--                  المستفيدين: عرض البحث                       -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_search" model="ir.ui.view">
            <field name="name">kser.beneficiary.search</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <search string="بحث في المستفيدين">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="district" string="المحلية"/>
                    <separator/>
                    <filter name="filter_verified" string="تم التحقق" domain="[('is_verified', '=', True)]"/>
                    <filter name="filter_not_verified" string="لم يتم التحقق" domain="[('is_verified', '=', False)]"/>
                    <separator/>
                    <filter name="filter_disabled" string="ذوو احتياجات خاصة" domain="[('is_disabled', '=', True)]"/>
                    <filter name="filter_child" string="أطفال" domain="[('is_child', '=', True)]"/>
                    <filter name="filter_widowed_females" string="الأرامل الإناث" domain="[('marital_status', '=', 'widowed'), ('gender', '=', 'female')]"/>
                    <separator/>
                    <filter name="inactive" string="مؤرشف" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="تجميع حسب">
                        <filter name="group_district" string="المحلية" context="{'group_by': 'district'}"/>
                        <filter name="group_disabled" string="ذوو احتياجات خاصة" context="{'group_by': 'is_disabled'}"/>
                        <filter name="group_child" string="طفل" context="{'group_by': 'is_child'}"/>
                        <filter name="group_marital" string="الحالة الاجتماعية" context="{'group_by': 'marital_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  المستفيدين: عرض القائمة                     -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_tree" model="ir.ui.view">
            <field name="name">kser.beneficiary.list</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <list string="قائمة المستفيدين"
                      js_class="kser_ocr_list">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="district" string="المحلية"/>
                    <field name="family_size" string="عدد أفراد الأسرة"/>
                    <field name="is_disabled" string="احتياجات خاصة"/>
                    <field name="registration_date" string="تاريخ التسجيل" optional="hide"/>
                    <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  المستفيدين: عرض النموذج                     -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_form" model="ir.ui.view">
            <field name="name">kser.beneficiary.form</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <form string="بيانات المستفيد">
                    <sheet>
                        <field name="id" invisible="1"/>
                        <div class="oe_button_box" name="button_box" style="gap: 10px;">
                            <button name="action_view_moves" type="object"
                                    class="oe_stat_button" icon="fa-truck">
                                <div class="o_stat_info">
                                    <field name="move_count" class="o_stat_value"/>
                                    <span class="o_stat_text">المساعدات المستلمة</span>
                                </div>
                            </button>
                            <button name="action_view_family_members" type="object"
                                    class="oe_stat_button" icon="fa-users"
                                    invisible="not is_head_of_family">
                                <div class="o_stat_info">
                                    <field name="family_member_count" class="o_stat_value"/>
                                    <span class="o_stat_text">أفراد الأسرة</span>
                                </div>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="تم التحقق" bg_color="text-bg-success"
                                invisible="not is_verified"/>
                        <widget name="web_ribbon" title="لم يتم التحقق" bg_color="text-bg-danger"
                                invisible="is_verified"/>
                        <div class="oe_title">
                            <h1>
                                <field name="partner_id" string="اسم المستفيد" placeholder="ادخل الاسم هنا..." readonly="is_verified"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="without_national_id" invisible="is_verified or national_id_image != False or national_id_number != False" readonly="is_verified"/>
                            </group>
                        </group>

                        <group invisible="not is_verified and not without_national_id and not national_id_number and not national_id_image">
                            <!-- العمود الأيمن: البيانات الشخصية وصلة القرابة -->
                            <group string="البيانات الأساسية والتحقق">
                                <field name="is_child" string="طفل" readonly="is_verified" invisible="is_verified and not is_child"/>
                                <field name="is_disabled" string="ذوو احتياجات خاصة" readonly="is_verified" invisible="is_verified and not is_disabled"/>
                                <field name="national_id_number" string="رقم الهوية الوطنية" readonly="is_verified or national_id_number" invisible="is_child or (is_verified and not national_id_number)"/>
                                <label for="phone" string="رقم الهاتف" invisible="is_verified and not phone"/>
                                <div class="o_row" invisible="is_verified and not phone">
                                    <field name="phone" placeholder="مثال: 0924747508" readonly="is_verified"/>
                                    <button name="action_open_whatsapp_phone" type="object" class="btn-success" icon="fa-whatsapp" title="مراسلة عبر واتساب" invisible="not phone"/>
                                </div>

                                <label for="mobile" string="رقم الجوال" invisible="is_verified and not mobile"/>
                                <div class="o_row" invisible="is_verified and not mobile">
                                    <field name="mobile" placeholder="مثال: 0912345678" readonly="is_verified"/>
                                    <button name="action_open_whatsapp_mobile" type="object" class="btn-success" icon="fa-whatsapp" title="مراسلة عبر واتساب" invisible="not mobile"/>
                                </div>

                                <label for="whatsapp_number" string="رقم الواتساب" invisible="not is_head_of_family or (is_verified and not whatsapp_number)"/>
                                <div class="o_row" invisible="not is_head_of_family or (is_verified and not whatsapp_number)">
                                    <field name="whatsapp_number" placeholder="مثال: 0912345678" readonly="is_verified"/>
                                    <button name="action_open_whatsapp" type="object" class="btn-success" icon="fa-whatsapp" title="مراسلة عبر واتساب" invisible="not whatsapp_number"/>
                                </div>
                                <field name="is_head_of_family" string="هل هو رب أسرة؟ / فرد لوحده" widget="boolean_toggle" readonly="is_verified" invisible="is_verified and not is_head_of_family"/>
                                <field name="relationship" string="العلاقة برب الأسرة" invisible="is_head_of_family or (is_verified and not relationship)" required="not is_head_of_family" readonly="is_verified"/>
                                <field name="head_of_family_id" string="رب الأسرة المسؤول" invisible="is_head_of_family or (is_verified and not head_of_family_id)" required="not is_head_of_family" domain="[('is_head_of_family', '=', True), ('id', '!=', id)]" readonly="is_verified"/>
                                <field name="profession" string="المهنة" invisible="is_child or (is_verified and not profession)" readonly="is_verified"/>
                                <field name="marital_status" string="الحالة الاجتماعية" invisible="is_child or (is_verified and not marital_status)" readonly="is_verified"/>
                                <field name="gender" string="الجنس" readonly="is_verified" invisible="is_verified and not gender"/>
                                <field name="birthdate" string="تاريخ الميلاد" readonly="is_verified" invisible="is_verified and not birthdate"/>
                                <field name="family_size" string="عدد أفراد الأسرة" invisible="is_child or (is_verified and not family_size)" readonly="is_verified"/>
                                <field name="district" string="المحلية"/>
                                <field name="address" string="عنوان السكن" placeholder="اسم الشارع / الحارة / الحي / علامة مميزة"/>
                            </group>
                            <!-- العمود الأيسر: صورة الرقم الوطني وبيانات التسجيل -->
                            <group>
                                <group string="الهوية الوطنية" colspan="2" invisible="is_child or (is_verified and not national_id_image)">
                                    <field name="national_id_image" string="صورة الهوية الوطنية"
                                            widget="image" class="oe_avatar" options="{'size': [2048, 2048]}" readonly="1"/>
                                    <field name="extracted_mother_name" string="اسم الوالدة" readonly="is_verified" invisible="is_verified and not extracted_mother_name"/>
                                </group>
                                <group string="بيانات التسجيل" colspan="2">
                                    <field name="registration_date" string="تاريخ التسجيل" readonly="is_verified" invisible="is_verified and not registration_date"/>
                                    <field name="registered_by" string="مسجّل بواسطة" readonly="is_verified" invisible="is_verified and not registered_by"/>
                                    <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </group>

                        <notebook invisible="not is_verified and not without_national_id and not national_id_number and not national_id_image">
                            <page string="أفراد الأسرة" name="family_members" invisible="not is_head_of_family">
                                <field name="family_member_ids" domain="[('is_head_of_family', '=', True), ('id', '!=', id)]">
                                    <list editable="bottom">
                                        <field name="partner_id" string="اسم المستفيد" readonly="1"/>
                                        <field name="national_id_number" string="رقم الهوية الوطنية" readonly="1"/>
                                        <field name="phone" string="رقم الهاتف" readonly="1"/>
                                        <field name="relationship" string="العلاقة برب الأسرة"/>
                                        <field name="is_verified" string="تم التحقق" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="الحالة الصحية" name="page_health">
                                <group>
                                    <group string="الحالة الصحية">
                                        <field name="health_conditions" string="الأمراض المزمنة" widget="many2many_tags"/>
                                    </group>
                                </group>
                            </page>
                            <page string="متابعة سوء التغذية" name="child_followups" invisible="not is_child">
                                <field name="followup_line_ids" readonly="1">
                                    <list>
                                        <field name="followup_date" string="التاريخ"/>
                                        <field name="weight" string="الوزن (كجم)"/>
                                        <field name="height" string="الطول (سم)"/>
                                        <field name="nutrition_status" string="الحالة الغذائية" widget="badge"
                                               decoration-danger="nutrition_status == 'severe'"
                                               decoration-warning="nutrition_status == 'moderate'"
                                               decoration-success="nutrition_status == 'normal'"/>
                                        <field name="visit_location" string="مكان الزيارة"/>
                                        <field name="measured_by" string="تم القياس بواسطة"/>
                                    </list>
                                </field>
                            </page>
                            <page string="المساعدات المستلمة" name="aids_received">
                                <group string="المساعدات المالية">
                                    <field name="financial_aid_ids" string="المساعدات المالية المستلمة" readonly="1">
                                        <list>
                                            <field name="name" string="رقم المستند"/>
                                            <field name="date" string="تاريخ الصرف"/>
                                            <field name="campaign_id" string="الحملة المرتبطة"/>
                                            <field name="amount" string="المبلغ المستلم"/>
                                            <field name="notes" string="ملاحظات وتفاصيل"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="المساعدات العينية الإغاثية">
                                    <field name="move_ids" string="المواد الإغاثية المستلمة" readonly="1">
                                        <list>
                                            <field name="reference" string="إذن التوزيع"/>
                                            <field name="date" string="تاريخ التوزيع"/>
                                            <field name="product_id" string="المادة الموزعة"/>
                                            <field name="product_uom_qty" string="الكمية"/>
                                            <field name="product_uom" string="الوحدة"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="المساعدات العينية العلاجية">
                                    <field name="prescription_ids" string="الروشتات الطبية المستلمة" readonly="1">
                                        <list>
                                            <field name="name" string="رقم الروشتة"/>
                                            <field name="prescription_date" string="تاريخ الروشتة"/>
                                            <field name="visit_id" string="زيارة العيادة"/>
                                            <field name="doctor_id" string="الطبيب المعالج"/>
                                            <field name="picking_id" string="إذن الصرف الصيدلاني"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  المستفيدين: العرض الرسومي                   -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_graph" model="ir.ui.view">
            <field name="name">kser.beneficiary.graph</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <graph string="المستفيدين" type="pie" sample="1">
                    <field name="district"/>
                </graph>
            </field>
        </record>

    </data>
</odoo>
