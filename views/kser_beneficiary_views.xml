<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Search View                    -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_search" model="ir.ui.view">
            <field name="name">kser.beneficiary.search</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <search string="بحث في المستفيدين">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="district" string="المحلية"/>
                    <separator/>
                    <filter name="filter_verified" string="تم التحقق" domain="[('is_verified', '=', True)]"/>
                    <filter name="filter_not_verified" string="لم يتم التحقق" domain="[('is_verified', '=', False)]"/>
                    <separator/>
                    <filter name="filter_disabled" string="ذوو احتياجات خاصة" domain="[('is_disabled', '=', True)]"/>
                    <filter name="filter_child" string="أطفال" domain="[('is_child', '=', True)]"/>
                    <filter name="filter_widowed_females" string="الأرامل الإناث" domain="[('marital_status', '=', 'widowed'), ('gender', '=', 'female')]"/>
                    <separator/>
                    <filter name="inactive" string="مؤرشف" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="تجميع حسب">
                        <filter name="group_district" string="المحلية" context="{'group_by': 'district'}"/>
                        <filter name="group_disabled" string="ذوو احتياجات خاصة" context="{'group_by': 'is_disabled'}"/>
                        <filter name="group_child" string="طفل" context="{'group_by': 'is_child'}"/>
                        <filter name="group_marital" string="الحالة الاجتماعية" context="{'group_by': 'marital_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Tree View                      -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_tree" model="ir.ui.view">
            <field name="name">kser.beneficiary.list</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <list string="قائمة المستفيدين"
                      js_class="kser_ocr_list">
                    <field name="partner_id" string="اسم المستفيد"/>
                    <field name="national_id_number" string="رقم الهوية"/>
                    <field name="phone" string="الهاتف"/>
                    <field name="district" string="المحلية"/>
                    <field name="family_size" string="عدد أفراد الأسرة"/>
                    <field name="is_disabled" string="احتياجات خاصة"/>
                    <field name="registration_date" string="تاريخ التسجيل" optional="hide"/>
                    <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Form View                      -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_form" model="ir.ui.view">
            <field name="name">kser.beneficiary.form</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <form string="بيانات المستفيد">
                    <sheet>
                        <field name="id" invisible="1"/>
                        <div class="oe_button_box" name="button_box" style="gap: 10px;">
                            <button name="action_view_moves" type="object"
                                    class="oe_stat_button" icon="fa-truck">
                                <div class="o_stat_info">
                                    <field name="move_count" class="o_stat_value"/>
                                    <span class="o_stat_text">المساعدات المستلمة</span>
                                </div>
                            </button>
                            <button name="action_view_family_members" type="object"
                                    class="oe_stat_button" icon="fa-users"
                                    invisible="not is_head_of_family">
                                <div class="o_stat_info">
                                    <field name="family_member_count" class="o_stat_value"/>
                                    <span class="o_stat_text">أفراد الأسرة</span>
                                </div>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="تم التحقق" bg_color="text-bg-success"
                                invisible="not is_verified"/>
                        <widget name="web_ribbon" title="لم يتم التحقق" bg_color="text-bg-danger"
                                invisible="is_verified"/>
                        <div class="oe_title">
                            <h1>
                                <field name="partner_id" string="اسم المستفيد" placeholder="ادخل الاسم هنا..."/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="without_national_id"/>
                            </group>
                        </group>

                        <group invisible="not without_national_id and not national_id_number and not national_id_image">
                            <!-- Right Column: Personal & Relationship Data -->
                            <group string="البيانات الأساسية والتحقق">
                                <field name="is_child" string="طفل"/>
                                <field name="is_disabled" string="ذوو احتياجات خاصة"/>
                                <field name="national_id_number" string="رقم الهوية الوطنية" invisible="is_child"/>
                                <field name="phone" string="رقم الهاتف"/>
                                <field name="mobile" string="رقم الجوال"/>
                                <label for="whatsapp_number" string="رقم الواتساب" invisible="not is_head_of_family"/>
                                <div class="o_row" invisible="not is_head_of_family">
                                    <field name="whatsapp_number" placeholder="مثال: 0912345678"/>
                                    <button name="action_open_whatsapp" type="object" class="btn-success" icon="fa-whatsapp" title="مراسلة عبر واتساب" invisible="not whatsapp_number"/>
                                </div>
                                <field name="is_head_of_family" string="هل هو رب أسرة؟ / فرد لوحده" widget="boolean_toggle"/>
                                <field name="relationship" string="العلاقة برب الأسرة" invisible="is_head_of_family" required="not is_head_of_family"/>
                                <field name="head_of_family_id" string="رب الأسرة المسؤول" invisible="is_head_of_family" required="not is_head_of_family" domain="[('is_head_of_family', '=', True), ('id', '!=', id)]"/>
                                <field name="profession" string="المهنة" invisible="is_child"/>
                                <field name="marital_status" string="الحالة الاجتماعية" invisible="is_child"/>
                                <field name="gender" string="الجنس"/>
                                <field name="birthdate" string="تاريخ الميلاد"/>
                                <field name="family_size" string="عدد أفراد الأسرة" invisible="is_child"/>
                                <field name="district" string="المحلية"/>
                                <field name="address" string="عنوان السكن" placeholder="اسم الشارع / الحارة / الحي / علامة مميزة"/>
                            </group>
                            <!-- Left Column: National ID Image & Registration Data -->
                            <group>
                                <group string="الهوية الوطنية" colspan="2" invisible="is_child">
                                    <field name="national_id_image" string="صورة الهوية الوطنية"
                                            widget="image" class="oe_avatar" options="{'size': [2048, 2048]}" readonly="1"/>
                                    <field name="extracted_mother_name" string="اسم الوالدة"/>
                                </group>
                                <group string="بيانات التسجيل" colspan="2">
                                    <field name="registration_date" string="تاريخ التسجيل"/>
                                    <field name="registered_by" string="مسجّل بواسطة"/>
                                    <field name="is_verified" string="تم التحقق" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </group>

                        <notebook invisible="not without_national_id and not national_id_number and not national_id_image">
                            <page string="أفراد الأسرة" name="family_members" invisible="not is_head_of_family">
                                <field name="family_member_ids" domain="[('is_head_of_family', '=', True), ('id', '!=', id)]">
                                    <list editable="bottom">
                                        <field name="partner_id" string="اسم المستفيد" readonly="1"/>
                                        <field name="national_id_number" string="رقم الهوية الوطنية" readonly="1"/>
                                        <field name="phone" string="رقم الهاتف" readonly="1"/>
                                        <field name="relationship" string="العلاقة برب الأسرة"/>
                                        <field name="is_verified" string="تم التحقق" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="الحالة الصحية" name="page_health">
                                <group>
                                    <group string="الحالة الصحية">
                                        <field name="health_conditions" string="الأمراض المزمنة" widget="many2many_tags"/>
                                    </group>
                                </group>
                            </page>
                            <page string="المساعدات المستلمة" name="aids_received">
                                <group string="المساعدات المالية">
                                    <field name="financial_aid_ids" string="المساعدات المالية المستلمة" readonly="1">
                                        <list>
                                            <field name="name" string="رقم المستند"/>
                                            <field name="date" string="تاريخ الصرف"/>
                                            <field name="campaign_id" string="الحملة المرتبطة"/>
                                            <field name="amount" string="المبلغ المستلم"/>
                                            <field name="notes" string="ملاحظات وتفاصيل"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="المساعدات العينية الإغاثية">
                                    <field name="move_ids" string="المواد الإغاثية المستلمة" readonly="1">
                                        <list>
                                            <field name="reference" string="إذن التوزيع"/>
                                            <field name="date" string="تاريخ التوزيع"/>
                                            <field name="product_id" string="المادة الموزعة"/>
                                            <field name="product_uom_qty" string="الكمية"/>
                                            <field name="product_uom" string="الوحدة"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="المساعدات العينية العلاجية">
                                    <field name="prescription_ids" string="الروشتات الطبية المستلمة" readonly="1">
                                        <list>
                                            <field name="name" string="رقم الروشتة"/>
                                            <field name="prescription_date" string="تاريخ الروشتة"/>
                                            <field name="visit_id" string="زيارة العيادة"/>
                                            <field name="doctor_id" string="الطبيب المعالج"/>
                                            <field name="picking_id" string="إذن الصرف الصيدلاني"/>
                                            <field name="state" string="الحالة"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Beneficiary: Graph View                     -->
        <!-- ============================================================ -->
        <record id="view_kser_beneficiary_graph" model="ir.ui.view">
            <field name="name">kser.beneficiary.graph</field>
            <field name="model">kser.beneficiary</field>
            <field name="arch" type="xml">
                <graph string="المستفيدين" type="pie" sample="1">
                    <field name="district"/>
                </graph>
            </field>
        </record>

    </data>
</odoo>
