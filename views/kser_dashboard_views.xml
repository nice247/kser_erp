<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- 1. Inventory Graph Action -->
        <record id="action_inventory_dashboard_graph" model="ir.actions.act_window">
            <field name="name">حالة مخزون الأدوية والإغاثة</field>
            <field name="res_model">stock.quant</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="stock.stock_quant_view_graph"/>
            <field name="context">{'search_default_internal_loc': 1, 'search_default_in_stock': 1}</field>
        </record>

        <!-- 2. Cash Donations List Action -->
        <record id="action_donations_dashboard_list" model="ir.actions.act_window">
            <field name="name">أحدث التبرعات المستلمة</field>
            <field name="res_model">kser.cash.donation</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_kser_cash_donation_tree"/>
            <field name="limit">5</field>
        </record>

        <!-- 3. Relief Campaigns Kanban Action -->
        <record id="action_campaigns_dashboard_kanban" model="ir.actions.act_window">
            <field name="name">الحملات الإغاثية (النشطة والقادمة)</field>
            <field name="res_model">project.project</field>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="project.view_project_kanban"/>
        </record>

        <!-- 4. Beneficiaries Pie Chart Action -->
        <record id="action_beneficiaries_dashboard_pie" model="ir.actions.act_window">
            <field name="name">توزيع المستفيدين حسب الأولوية</field>
            <field name="res_model">kser.beneficiary</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="kser_erp.view_kser_beneficiary_graph"/>
        </record>

        <!-- 5. Active Tasks List Action -->
        <record id="action_tasks_dashboard_list" model="ir.actions.act_window">
            <field name="name">آخر المهام الميدانية النشطة</field>
            <field name="res_model">project.task</field>
            <field name="view_mode">list</field>
            <field name="limit">5</field>
            <field name="domain">[('state', 'not in', ('1_done', '1_canceled'))]</field>
        </record>

        <!-- 6. Recent Audit Logs List Action -->
        <record id="action_audit_dashboard_list" model="ir.actions.act_window">
            <field name="name">سجلات التدقيق الأخيرة</field>
            <field name="res_model">kser.audit.log</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_kser_audit_log_tree"/>
            <field name="limit">5</field>
        </record>

        <!-- 7. Contacts List Action -->
        <record id="action_contacts_dashboard_list" model="ir.actions.act_window">
            <field name="name">أحدث سجلات جهات الاتصال المسجلة</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_res_partner_tree_kser"/>
            <field name="domain" eval="[('user_ids', '=', False), ('is_company', '=', False)]"/>
            <field name="limit">5</field>
        </record>

        <!-- 8. Single Unified Dashboard View -->
        <record id="kser_emergency_dashboard_view" model="ir.ui.view">
            <field name="name">kser.emergency.dashboard.view</field>
            <field name="model">board.board</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="لوحة تحكم غرفة الطوارئ">
                    <board style="1-1-1">
                        <column>
                            <action name="%(action_inventory_dashboard_graph)d" 
                                    string="حالة مخزون الأدوية والإغاثة"
                                    groups="kser_erp.group_stock_manager,kser_erp.group_system_admin"/>
                            <action name="%(action_campaigns_dashboard_kanban)d" 
                                    string="الحملات الإغاثية (النشطة والقادمة)"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                        </column>
                        <column>
                            <action name="%(action_beneficiaries_dashboard_pie)d" 
                                    string="توزيع المستفيدين حسب الأولوية"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_stock_manager,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_donations_dashboard_list)d" 
                                    string="أحدث التبرعات المستلمة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_system_admin"/>
                        </column>
                        <column>
                            <action name="%(action_tasks_dashboard_list)d" 
                                    string="آخر المهام الميدانية النشطة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_audit_dashboard_list)d" 
                                    string="سجلات التدقيق الأخيرة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_contacts_dashboard_list)d" 
                                    string="أحدث سجلات جهات الاتصال المسجلة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                        </column>
                    </board>
                </form>
            </field>
        </record>

        <!-- 9. Dashboard Action -->
        <record id="action_kser_emergency_dashboard" model="ir.actions.act_window">
            <field name="name">لوحة القيادة</field>
            <field name="res_model">board.board</field>
            <field name="view_mode">form</field>
            <field name="usage">menu</field>
            <field name="view_id" ref="kser_emergency_dashboard_view"/>
        </record>

    </data>
</odoo>
