<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- 1. Inventory Graph Action -->
        <record id="action_inventory_dashboard_graph" model="ir.actions.act_window">
            <field name="name">حالة مخزون الأدوية والإغاثة</field>
            <field name="res_model">stock.quant</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="stock.stock_quant_view_graph"/>
            <field name="context">{'search_default_internal_loc': 1, 'search_default_in_stock': 1}</field>
        </record>

        <!-- 2. Cash Donations List Action -->
        <record id="action_donations_dashboard_list" model="ir.actions.act_window">
            <field name="name">أحدث التبرعات المستلمة</field>
            <field name="res_model">kser.cash.donation</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_kser_cash_donation_tree"/>
            <field name="limit">5</field>
        </record>

        <!-- 3. Relief Campaigns Kanban Action -->
        <record id="action_campaigns_dashboard_kanban" model="ir.actions.act_window">
            <field name="name">الحملات الإغاثية (النشطة والقادمة)</field>
            <field name="res_model">project.project</field>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="project.view_project_kanban"/>
        </record>

        <!-- 4. Beneficiaries Pie Chart Action -->
        <record id="action_beneficiaries_dashboard_pie" model="ir.actions.act_window">
            <field name="name">توزيع المستفيدين حسب المحلية</field>
            <field name="res_model">kser.beneficiary</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="kser_erp.view_kser_beneficiary_graph"/>
        </record>

        <record id="action_visits_dashboard_graph" model="ir.actions.act_window">
            <field name="name">حالة زيارات العيادة اليومية</field>
            <field name="res_model">kser.clinic.visit</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="kser_erp.view_kser_clinic_visit_graph"/>
            <field name="domain">[('visit_date', '=', context_today())]</field>
        </record>

        <record id="view_kser_clinic_visit_frequency_graph" model="ir.ui.view">
            <field name="name">kser.clinic.visit.frequency.graph</field>
            <field name="model">kser.clinic.visit</field>
            <field name="arch" type="xml">
                <graph string="تردد زيارات المرضى" type="bar" sample="1">
                    <field name="visit_date" interval="day"/>
                </graph>
            </field>
        </record>

        <record id="action_visits_frequency_graph" model="ir.actions.act_window">
            <field name="name">معدل تردد زيارات المرضى</field>
            <field name="res_model">kser.clinic.visit</field>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="view_kser_clinic_visit_frequency_graph"/>
        </record>

        <record id="view_prescription_tree_kser_dashboard" model="ir.ui.view">
            <field name="name">kser.prescription.tree.kser.dashboard</field>
            <field name="model">kser.prescription</field>
            <field name="arch" type="xml">
                <list string="الروشتات الأخيرة" default_order="create_date desc">
                    <field name="name" string="رقم الروشتة"/>
                    <field name="beneficiary_id" string="المستفيد"/>
                    <field name="prescription_date" string="التاريخ"/>
                    <field name="state" string="الحالة"/>
                </list>
            </field>
        </record>

        <record id="action_prescriptions_dashboard_list" model="ir.actions.act_window">
            <field name="name">آخر الروشتات الطبية الصادرة</field>
            <field name="res_model">kser.prescription</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_prescription_tree_kser_dashboard"/>
            <field name="limit">5</field>
        </record>

        <record id="view_child_followup_tree_kser_dashboard" model="ir.ui.view">
            <field name="name">kser.child.followup.tree.kser.dashboard</field>
            <field name="model">kser.child.followup</field>
            <field name="arch" type="xml">
                <list string="متابعات سوء التغذية الأخيرة" default_order="create_date desc">
                    <field name="beneficiary_id" string="الطفل"/>
                    <field name="followup_date" string="التاريخ"/>
                    <field name="nutrition_status" string="الحالة"/>
                </list>
            </field>
        </record>

        <record id="action_followups_dashboard_list" model="ir.actions.act_window">
            <field name="name">آخر متابعات سوء التغذية للأطفال</field>
            <field name="res_model">kser.child.followup</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_child_followup_tree_kser_dashboard"/>
            <field name="limit">5</field>
        </record>

        <record id="action_prescriptions_pending_dispense_list" model="ir.actions.act_window">
            <field name="name">روشتات في انتظار الصرف</field>
            <field name="res_model">kser.prescription</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_prescription_tree_kser_dashboard"/>
            <field name="domain">[('state', '=', 'prescribed')]</field>
            <field name="limit">5</field>
        </record>

        <!-- 5. Active Tasks List Action -->
        <record id="view_project_task_tree_kser_dashboard" model="ir.ui.view">
            <field name="name">project.task.tree.kser.dashboard</field>
            <field name="model">project.task</field>
            <field name="arch" type="xml">
                <list string="المهام" default_order="create_date desc">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="date_deadline"/>
                </list>
            </field>
        </record>

        <record id="action_tasks_dashboard_list" model="ir.actions.act_window">
            <field name="name">آخر المهام الميدانية النشطة</field>
            <field name="res_model">project.task</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_project_task_tree_kser_dashboard"/>
            <field name="limit">5</field>
            <field name="domain">[('state', 'not in', ('1_done', '1_canceled'))]</field>
        </record>

        <!-- 6. Recent Audit Logs List Action -->
        <record id="action_audit_dashboard_list" model="ir.actions.act_window">
            <field name="name">سجلات التدقيق الأخيرة</field>
            <field name="res_model">kser.audit.log</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_kser_audit_log_tree"/>
            <field name="limit">5</field>
        </record>

        <!-- 7. Contacts List Action -->
        <record id="action_contacts_dashboard_list" model="ir.actions.act_window">
            <field name="name">احدث السجلات المسجلة</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="kser_erp.view_res_partner_tree_kser"/>
            <field name="domain">[('category_tag', '!=', False), '|', ('is_volunteer', '=', True), ('is_beneficiary', '=', True)]</field>
            <field name="limit">5</field>
        </record>

        <!-- 8. Single Unified Dashboard View -->
        <record id="kser_emergency_dashboard_view" model="ir.ui.view">
            <field name="name">kser.emergency.dashboard.view</field>
            <field name="model">board.board</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="لوحة تحكم غرفة الطوارئ">
                    <board style="1-1">
                        <column>
                            <action name="%(action_visits_dashboard_graph)d" 
                                     string="حالة زيارات العيادة اليومية"
                                     groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_system_admin,kser_erp.group_receptionist"/>
                            <action name="%(action_inventory_dashboard_graph)d" 
                                    string="حالة مخزون الأدوية والإغاثة"
                                    groups="kser_erp.group_stock_manager,kser_erp.group_pharmacist,kser_erp.group_system_admin"/>
                            <action name="%(action_prescriptions_dashboard_list)d" 
                                    string="آخر الروشتات الطبية الصادرة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_pharmacist,kser_erp.group_system_admin"/>
                            <action name="%(action_beneficiaries_dashboard_pie)d" 
                                    string="توزيع المستفيدين حسب المحلية"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_stock_manager,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_tasks_dashboard_list)d" 
                                    string="آخر المهام الميدانية النشطة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_audit_dashboard_list)d" 
                                    string="سجلات التدقيق الأخيرة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                        </column>
                        <column>
                            <action name="%(action_visits_frequency_graph)d" 
                                     string="معدل تردد زيارات المرضى"
                                     groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_system_admin,kser_erp.group_receptionist"/>
                            <action name="%(action_prescriptions_pending_dispense_list)d" 
                                    string="روشتات في انتظار الصرف"
                                    groups="kser_erp.group_pharmacist,kser_erp.group_clinic_manager,kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_campaigns_dashboard_kanban)d" 
                                    string="الحملات الإغاثية (النشطة والقادمة)"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_field_supervisor,kser_erp.group_system_admin"/>
                            <action name="%(action_followups_dashboard_list)d" 
                                    string="آخر متابعات سوء التغذية للأطفال"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_clinic_manager,kser_erp.group_doctor,kser_erp.group_system_admin"/>
                            <action name="%(action_donations_dashboard_list)d" 
                                    string="أحدث التبرعات المستلمة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_data_manager,kser_erp.group_system_admin"/>
                            <action name="%(action_contacts_dashboard_list)d" 
                                    string="احدث السجلات المسجلة"
                                    groups="kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                        </column>
                    </board>
                </form>
            </field>
        </record>

        <!-- 9. Dashboard Action -->
        <record id="action_kser_emergency_dashboard" model="ir.actions.act_window">
            <field name="name">لوحة القيادة</field>
            <field name="res_model">board.board</field>
            <field name="view_mode">form</field>
            <field name="usage">menu</field>
            <field name="view_id" ref="kser_emergency_dashboard_view"/>
        </record>

    </data>
</odoo>
