<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_kser_clinic_visit_search" model="ir.ui.view">
            <field name="name">kser.clinic.visit.search</field>
            <field name="model">kser.clinic.visit</field>
            <field name="arch" type="xml">
                <search string="بحث زيارات العيادة">
                    <field name="name" string="رقم الزيارة"/>
                    <field name="beneficiary_id" string="المريض"/>
                    <field name="doctor_id" string="الطبيب المعالج"/>
                    <field name="receptionist_id" string="موظف الاستقبال"/>
                    <filter name="filter_waiting" string="في الانتظار" domain="[('state', '=', 'waiting')]"/>
                    <filter name="filter_consultation" string="قيد الفحص" domain="[('state', '=', 'consultation')]"/>
                    <filter name="filter_done" string="مكتملة" domain="[('state', '=', 'done')]"/>
                    <filter name="filter_cancelled" string="ملغاة" domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter name="filter_today" string="زيارات اليوم" domain="[('visit_date', '=', context_today())]"/>
                    <group expand="0" string="تجميع حسب">
                        <filter name="group_doctor" string="الطبيب" context="{'group_by': 'doctor_id'}"/>
                        <filter name="group_state" string="الحالة" context="{'group_by': 'state'}"/>
                        <filter name="group_date" string="التاريخ" context="{'group_by': 'visit_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_kser_clinic_visit_tree" model="ir.ui.view">
            <field name="name">kser.clinic.visit.list</field>
            <field name="model">kser.clinic.visit</field>
            <field name="arch" type="xml">
                <list string="زيارات العيادة" default_order="visit_time desc"
                      decoration-info="state == 'waiting'"
                      decoration-warning="state == 'consultation'"
                      decoration-success="state == 'done'"
                      decoration-muted="state == 'cancelled'">
                    <field name="name" string="رقم الزيارة"/>
                    <field name="beneficiary_id" string="المريض"/>
                    <field name="doctor_id" string="الطبيب المعالج"/>
                    <field name="receptionist_id" string="موظف الاستقبال"/>
                    <field name="visit_date" string="تاريخ الزيارة"/>
                    <field name="visit_time" string="وقت الوصول"/>
                    <field name="state" string="الحالة" widget="badge"
                           decoration-info="state == 'waiting'"
                           decoration-warning="state == 'consultation'"
                           decoration-success="state == 'done'"
                           decoration-danger="state == 'cancelled'"/>
                </list>
            </field>
        </record>

        <record id="view_kser_clinic_visit_form" model="ir.ui.view">
            <field name="name">kser.clinic.visit.form</field>
            <field name="model">kser.clinic.visit</field>
            <field name="arch" type="xml">
                <form string="زيارة العيادة">
                    <header>
                        <button name="action_set_consultation" type="object" string="بدء الفحص"
                                class="btn-primary" invisible="state != 'waiting'"
                                groups="kser_erp.group_doctor,kser_erp.group_clinic_manager,kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                        <button name="action_set_done" type="object" string="إكمال الزيارة"
                                class="btn-success" invisible="state != 'consultation'"
                                groups="kser_erp.group_doctor,kser_erp.group_clinic_manager,kser_erp.group_admin_supervisor,kser_erp.group_system_admin"/>
                        <button name="action_set_cancelled" type="object" string="إلغاء الزيارة"
                                class="btn-secondary" invisible="state in ('done', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="waiting,consultation,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="بيانات الزيارة">
                                <field name="beneficiary_id" string="المريض"/>
                                <field name="doctor_id" string="الطبيب المعالج"/>
                                <field name="receptionist_id" string="موظف الاستقبال"/>
                            </group>
                            <group string="التوقيت">
                                <field name="visit_date" string="التاريخ"/>
                                <field name="visit_time" string="وقت الوصول"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="الروشتات الصادرة" name="prescriptions" invisible="state == 'waiting'">
                                <field name="prescription_ids" 
                                       groups="kser_erp.group_doctor,kser_erp.group_clinic_manager,kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                                       context="{'default_beneficiary_id': beneficiary_id, 'default_doctor_id': doctor_id, 'default_visit_id': id}">
                                    <list>
                                        <field name="name" string="رقم الروشتة"/>
                                        <field name="prescription_date" string="التاريخ"/>
                                        <field name="state" string="الحالة"/>
                                    </list>
                                </field>
                                <field name="prescription_ids" 
                                       groups="kser_erp.group_receptionist,kser_erp.group_pharmacist"
                                       readonly="1">
                                    <list>
                                        <field name="name" string="رقم الروشتة"/>
                                        <field name="prescription_date" string="التاريخ"/>
                                        <field name="state" string="الحالة"/>
                                    </list>
                                </field>
                            </page>
                            <page string="متابعات سوء التغذية" name="followups" invisible="state == 'waiting'">
                                <field name="followup_ids" 
                                       groups="kser_erp.group_doctor,kser_erp.group_clinic_manager,kser_erp.group_admin_supervisor,kser_erp.group_system_admin"
                                       context="{'default_beneficiary_id': beneficiary_id, 'default_measured_by': uid, 'default_visit_id': id}">
                                    <list>
                                        <field name="followup_date" string="التاريخ"/>
                                        <field name="weight" string="الوزن"/>
                                        <field name="height" string="الطول"/>
                                        <field name="nutrition_status" string="الحالة"/>
                                    </list>
                                </field>
                                <field name="followup_ids" 
                                       groups="kser_erp.group_receptionist,kser_erp.group_pharmacist"
                                       readonly="1">
                                    <list>
                                        <field name="followup_date" string="التاريخ"/>
                                        <field name="weight" string="الوزن"/>
                                        <field name="height" string="الطول"/>
                                        <field name="nutrition_status" string="الحالة"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_kser_clinic_visit_graph" model="ir.ui.view">
            <field name="name">kser.clinic.visit.graph</field>
            <field name="model">kser.clinic.visit</field>
            <field name="arch" type="xml">
                <graph string="زيارات العيادة" type="pie" sample="1">
                    <field name="state"/>
                </graph>
            </field>
        </record>

        <record id="action_kser_clinic_visit_all" model="ir.actions.act_window">
            <field name="name">سجل الزيارات التاريخي</field>
            <field name="res_model">kser.clinic.visit</field>
            <field name="view_mode">list,form,graph</field>
            <field name="search_view_id" ref="view_kser_clinic_visit_search"/>
        </record>

        <record id="action_kser_clinic_visit_today" model="ir.actions.server">
            <field name="name">طابور العيادة اليومي</field>
            <field name="model_id" ref="model_kser_clinic_visit"/>
            <field name="state">code</field>
            <field name="code">
                action = model.action_view_today_queue()
            </field>
        </record>

    </data>
</odoo>
