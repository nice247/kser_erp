<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!--                  Audit Log: Search View                      -->
        <!-- ============================================================ -->
        <record id="view_kser_audit_log_search" model="ir.ui.view">
            <field name="name">kser.audit.log.search</field>
            <field name="model">kser.audit.log</field>
            <field name="arch" type="xml">
                <search string="بحث في سجل التدقيق">
                    <field name="user_id" string="المستخدم"/>
                    <field name="target_model" string="النموذج المستهدف"/>
                    <separator/>
                    <filter name="filter_create" string="إنشاء" domain="[('action_type', '=', 'create')]"/>
                    <filter name="filter_update" string="تعديل" domain="[('action_type', '=', 'update')]"/>
                    <filter name="filter_delete" string="حذف" domain="[('action_type', '=', 'delete')]"/>
                    <filter name="filter_approve" string="اعتماد" domain="[('action_type', '=', 'approve')]"/>
                    <separator/>
                    <group expand="0" string="تجميع حسب">
                        <filter name="group_user" string="المستخدم" context="{'group_by': 'user_id'}"/>
                        <filter name="group_action" string="نوع العملية" context="{'group_by': 'action_type'}"/>
                        <filter name="group_model" string="النموذج" context="{'group_by': 'target_model'}"/>
                        <filter name="group_date" string="التاريخ" context="{'group_by': 'timestamp:day'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Audit Log: Tree View                        -->
        <!-- ============================================================ -->
        <record id="view_kser_audit_log_tree" model="ir.ui.view">
            <field name="name">kser.audit.log.list</field>
            <field name="model">kser.audit.log</field>
            <field name="arch" type="xml">
                <list string="سجل التدقيق" create="0" edit="0" delete="0" default_order="create_date desc"
                      decoration-info="action_type == 'create'"
                      decoration-warning="action_type == 'update'"
                      decoration-danger="action_type == 'delete'"
                      decoration-success="action_type == 'approve'">
                    <field name="user_id" string="المستخدم"/>
                    <field name="action_type" string="نوع العملية"/>
                    <field name="target_model" string="النموذج المستهدف"/>
                    <field name="target_id" string="معرّف السجل" optional="hide"/>
                    <field name="timestamp" string="التوقيت"/>
                    <field name="ip_address" string="عنوان IP" optional="hide"/>
                    <field name="details" string="التفاصيل"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!--                  Audit Log: Form View                        -->
        <!-- ============================================================ -->
        <record id="view_kser_audit_log_form" model="ir.ui.view">
            <field name="name">kser.audit.log.form</field>
            <field name="model">kser.audit.log</field>
            <field name="arch" type="xml">
                <form string="تفاصيل سجل التدقيق" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group string="بيانات العملية">
                                <field name="user_id" string="المستخدم"/>
                                <field name="action_type" string="نوع العملية"/>
                                <field name="timestamp" string="التوقيت"/>
                                <field name="ip_address" string="عنوان IP"/>
                            </group>
                            <group string="السجل المستهدف">
                                <field name="target_model" string="النموذج المستهدف"/>
                                <field name="target_id" string="معرّف السجل"/>
                            </group>
                        </group>
                        <group string="التفاصيل">
                            <field name="details" string="تفاصيل إضافية" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
