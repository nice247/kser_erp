<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ==============================
             تصنيف الموديول
        ============================== -->
        <record id="module_category_kser" model="ir.module.category">
            <field name="name">KSER ERP</field>
            <field name="description">نظام إدارة غرف الطوارئ</field>
            <field name="sequence">50</field>
        </record>

        <!-- ==============================
             المجموعات (الأدوار)
        ============================== -->

        <!-- مستخدم أساسي (مخفي): لتقييد القوائم الأساسية -->
        <record id="group_kser_user" model="res.groups">
            <field name="name">مستخدم غرفة الطوارئ (أساسي)</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_receptionist" model="res.groups">
            <field name="name">موظف الاستقبال</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[(4, ref('group_kser_user'))]"/>
        </record>

        <record id="group_doctor" model="res.groups">
            <field name="name">الطبيب</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[(4, ref('group_kser_user'))]"/>
        </record>

        <record id="group_pharmacist" model="res.groups">
            <field name="name">الصيدلي</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[
                (4, ref('group_kser_user')),
                (4, ref('stock.group_stock_user'))
            ]"/>
        </record>

        <record id="group_clinic_manager" model="res.groups">
            <field name="name">مدير العيادة</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[(4, ref('group_kser_user'))]"/>
        </record>

        <record id="group_field_supervisor" model="res.groups">
            <field name="name">المشرف الميداني</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[(4, ref('group_kser_user'))]"/>
        </record>

        <record id="group_data_manager" model="res.groups">
            <field name="name">مسؤول البيانات</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[(4, ref('group_kser_user'))]"/>
        </record>

        <record id="group_stock_manager" model="res.groups">
            <field name="name">مسؤول المخازن</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[
                (4, ref('group_kser_user')),
                (4, ref('stock.group_stock_manager'))
            ]"/>
        </record>

        <record id="group_admin_supervisor" model="res.groups">
            <field name="name">المشرف الإداري العام</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[
                (4, ref('group_clinic_manager')),
                (4, ref('group_data_manager')),
                (4, ref('group_stock_manager')),
                (4, ref('account.group_account_manager'))
            ]"/>
        </record>

        <record id="group_system_admin" model="res.groups">
            <field name="name">مسؤول النظام</field>
            <field name="category_id" ref="module_category_kser"/>
            <field name="implied_ids" eval="[
                (4, ref('group_admin_supervisor'))
            ]"/>
            <field name="users" eval="[
                (4, ref('base.user_admin')),
                (4, ref('base.user_root'))
            ]"/>
        </record>

        <!-- ==========================================
             قواعد الوصول (Record Rules)
        =========================================== -->

        <!-- 1. قواعد Contacts (res.partner) -->
        <record id="rule_partner_own_records" model="ir.rule">
            <field name="name">Volunteers/Donors/Contacts: Own Records Only</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_stock_manager'))]"/>
            <field name="domain_force">['|', '|', '|', ('create_uid', '=', user.id), ('id', '=', user.partner_id.id), ('id', '=', user.company_id.partner_id.id), ('user_ids', '!=', False)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_partner_field_supervisor" model="ir.rule">
            <field name="name">Volunteers: Field Supervisor Records</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_field_supervisor'))]"/>
            <field name="domain_force">['|', ('is_volunteer', '=', True), ('id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_partner_system_admin_all" model="ir.rule">
            <field name="name">Contacts: System Admin All Records</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_system_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_partner_admin_all" model="ir.rule">
            <field name="name">Contacts: Admin Supervisor All Records</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_admin_supervisor'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_partner_data_manager_all" model="ir.rule">
            <field name="name">Contacts: Data Manager Read/Write/Create Non-Volunteers</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_data_manager'))]"/>
            <field name="domain_force">[('is_volunteer', '=', False)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_beneficiary_admin_all" model="ir.rule">
            <field name="name">Beneficiaries: Admin/Supervisor All Records</field>
            <field name="model_id" ref="kser_erp.model_kser_beneficiary"/>
            <field name="groups" eval="[
                (4, ref('group_data_manager')),
                (4, ref('group_admin_supervisor')),
                (4, ref('group_system_admin')),
                (4, ref('group_clinic_manager')),
                (4, ref('group_doctor')),
                (4, ref('group_pharmacist')),
                (4, ref('group_receptionist')),
                (4, ref('group_stock_manager')),
                (4, ref('group_field_supervisor'))
            ]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 3. قواعد Donations (kser.cash.donation) -->
        <record id="rule_donation_own_records" model="ir.rule">
            <field name="name">Donations: Own Records Only</field>
            <field name="model_id" ref="kser_erp.model_kser_cash_donation"/>
            <field name="groups" eval="[(4, ref('group_stock_manager'))]"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_donation_admin_all" model="ir.rule">
            <field name="name">Donations: Admin/Supervisor All Records</field>
            <field name="model_id" ref="kser_erp.model_kser_cash_donation"/>
            <field name="groups" eval="[(4, ref('group_data_manager')), (4, ref('group_admin_supervisor')), (4, ref('group_system_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_prescription_write_global" model="ir.rule">
            <field name="name">Clinic Prescriptions: Restrict Write Globally</field>
            <field name="model_id" ref="kser_erp.model_kser_prescription"/>
            <field name="domain_force">[(0, '=', 1)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_prescription_write_doctor" model="ir.rule">
            <field name="name">Clinic Prescriptions: Allow Write Doctor and Admin</field>
            <field name="model_id" ref="kser_erp.model_kser_prescription"/>
            <field name="groups" eval="[(4, ref('group_doctor')), (4, ref('group_admin_supervisor')), (4, ref('group_system_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_product_therapeutic_global" model="ir.rule">
            <field name="name">Therapeutic Products: Filter Globally</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="domain_force">[('is_therapeutic', '=', False)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_product_therapeutic_allowed" model="ir.rule">
            <field name="name">Therapeutic Products: Allow Clinic and Stock Groups</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="groups" eval="[(4, ref('group_pharmacist')), (4, ref('group_stock_manager')), (4, ref('group_admin_supervisor')), (4, ref('group_system_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 4. قواعد المخزون (stock.quant) حسب المجموعات -->
        <record id="rule_stock_quant_manager_admin" model="ir.rule">
            <field name="name">Stock Quants: Admin/Stock Manager see all</field>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="groups" eval="[(4, ref('group_stock_manager')), (4, ref('group_admin_supervisor')), (4, ref('group_system_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_stock_quant_therapeutic_only" model="ir.rule">
            <field name="name">Stock Quants: Clinic staff see therapeutic only</field>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="groups" eval="[(4, ref('group_pharmacist')), (4, ref('group_doctor')), (4, ref('group_clinic_manager'))]"/>
            <field name="domain_force">[('product_id.is_therapeutic', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_stock_quant_relief_only" model="ir.rule">
            <field name="name">Stock Quants: Field Supervisor see relief only</field>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="groups" eval="[(4, ref('group_field_supervisor'))]"/>
            <field name="domain_force">[('product_id.is_therapeutic', '=', False)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>